    "express": "^4.21.2",
    "firebase": "^12.12.1",
    "firebase-admin": "^13.8.0",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "nodemailer": "^8.0.7",
    "otpauth": "^9.5.1",
    "qrcode": "^1.5.4",
